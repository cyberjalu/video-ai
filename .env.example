# Job storage (server-side)
JOB_DATA_DIR=./data/jobs
JOB_TTL_HOURS=72
MAX_CONCURRENT_RENDERS=2

# Worker timeouts (ms)
WORKER_PLAN_TIMEOUT_MS=180000
WORKER_RENDER_TIMEOUT_MS=600000

# HMAC secret for anonymous job mutation tokens (change in production)
JOB_TOKEN_SECRET=change-me-to-a-long-random-string

# Optional CORS / origin allowlist (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# TikTok Content Posting API (Phase 4 — optional)
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=http://localhost:3000/api/tiktok/callback

# Optional: operator health checks only (users provide Gemini/Pexels via browser BYOK)
# GEMINI_API_KEY=

# Free-tier Gemini RPM safety (Peak requests/min). Free Flash ≈ 15 RPM — keep below.
# GEMINI_MAX_RPM=10
# GEMINI_MIN_GAP_MS=6000
# GEMINI_RETRY_MAX=5

# Director-level craft QC (default on). Set 0/false/off to skip craft check + craft rewrite.
# CRAFT_QC=1
